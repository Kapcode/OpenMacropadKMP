<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Using the pre-downsized 192px icon to avoid system scaling artifacts -->
    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/splash_icon_downsized"
            android:gravity="center" />
    </item>

    <!-- Cursor positioned below the icon's main content -->
    <item
        android:width="36dp"
        android:height="28dp"
        android:drawable="@drawable/ic_cursor_static"
        android:top="32dp"
        android:gravity="center" />
</layer-list>